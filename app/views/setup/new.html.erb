<div class="setup-page">
  <div class="setup-container">
    <div class="setup-header">
      <h1>🎬 Welcome to <span style="color: var(--accent);">NASFLIX</span></h1>
      <p style="color: var(--text-secondary); margin-top: 0.5rem; font-size: 1.1rem;">Let's get you started. Create your admin account.</p>
    </div>

    <%= form_with model: @user, url: setup_path, class: "form-container", style: "max-width: 500px; margin: 2rem auto;" do |f| %>
      <% if @user.errors.any? %>
        <div class="form-errors">
          <ul>
            <% @user.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="form-group">
        <%= f.label :name, "Your Name" %>
        <%= f.text_field :name, class: "form-control", placeholder: "e.g. Adam", autofocus: true %>
      </div>

      <div class="form-group">
        <%= f.label :email, "Email Address" %>
        <%= f.email_field :email, class: "form-control", placeholder: "admin@example.com" %>
      </div>

      <div class="form-group">
        <%= f.label :password, "Password" %>
        <%= f.password_field :password, class: "form-control", placeholder: "Choose a strong password" %>
      </div>

      <div class="form-group">
        <%= f.label :password_confirmation, "Confirm Password" %>
        <%= f.password_field :password_confirmation, class: "form-control", placeholder: "Re-enter your password" %>
      </div>

      <%= f.submit "Create Admin Account & Start", class: "btn btn-primary", style: "width: 100%; margin-top: 1rem; padding: 0.8rem;" %>
    <% end %>
  </div>
</div>
