<%= form_with model: user, class: "form-container" do |f| %>
  <% if user.errors.any? %>
    <div class="form-errors">
      <h3><%= pluralize(user.errors.count, "error") %> prevented saving:</h3>
      <ul>
        <% user.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form-row">
    <div class="form-group">
      <%= f.label :name %>
      <%= f.text_field :name, class: "form-control", placeholder: "Full Name" %>
    </div>
    
    <div class="form-group">
      <%= f.label :role %>
      <%= f.select :role, options_for_select([["Admin", "admin"], ["Parent", "parent"], ["Child", "child"]], user.role), {}, class: "form-control" %>
    </div>
  </div>

  <div class="form-group">
    <%= f.label :email %>
    <%= f.email_field :email, class: "form-control", placeholder: "you@example.com" %>
  </div>

  <div class="form-row">
    <div class="form-group">
      <%= f.label :password, user.persisted? ? "Password (leave blank to keep current)" : "Password" %>
      <%= f.password_field :password, class: "form-control", placeholder: "••••••••" %>
    </div>

    <div class="form-group">
      <%= f.label :password_confirmation, "Confirm Password" %>
      <%= f.password_field :password_confirmation, class: "form-control", placeholder: "••••••••" %>
    </div>
  </div>

  <%= f.submit class: "btn btn-primary" %>
<% end %>
